# Wheat Disease Detection System - Environment Variables
# Copy this file to .env and update values for your environment

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# Testing Configuration
FLASK_TESTING=False

# Session Configuration
SESSION_COOKIE_SECURE=False  # Set to True in production with HTTPS
SESSION_COOKIE_SAMESITE=Lax

# Logging Configuration
LOG_LEVEL=INFO
# LOG_FILE=/path/to/logfile.log  # Optional: specify log file path

# Database Configuration (for future use)
# DATABASE_URL=sqlite:///wheat_disease_detection.db

# API Configuration (for future use)
# API_RATE_LIMIT=100

# Security
# CORS_ORIGINS=http://localhost:5000,https://yourdomain.com

# Model Configuration
# MODEL_PATH=/custom/path/to/model.h5  # Optional: override default model location

# Development
# WERKZEUG_DEBUG_PIN=off  # Disable PIN in development if needed

# Production
# GUNICORN_WORKERS=4
# GUNICORN_THREADS=2
